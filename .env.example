COMPOSE_PROJECT_NAME=ai-workforce-platform
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:3000"]
POSTGRES_PUBLISHED_PORT=5432
REDIS_PUBLISHED_PORT=6379
FRONTEND_PUBLISHED_PORT=3000
API_WEB_CONCURRENCY=2
ENGINE_WEB_CONCURRENCY=2
RUNTIME_WEB_CONCURRENCY=2
DEBIAN_MIRROR=
DEBIAN_SECURITY_MIRROR=
PIP_INDEX_URL=
PIP_EXTRA_INDEX_URL=
PIP_TRUSTED_HOST=

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=platform_admin
POSTGRES_PASSWORD=change_me
POSTGRES_DB=platform
# 单库模式：所有服务共用该数据库
DATABASE_URL=postgresql+psycopg://platform_admin:change_me@postgres:5432/platform

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me

JWT_SECRET_KEY=replace_with_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_ISSUER=ai-workforce-platform
JWT_AUDIENCE=ai-workforce-platform-users
ACCESS_TOKEN_EXPIRE_MINUTES=30
INTERNAL_API_KEY=replace_with_internal_callback_secret
AUTH_REQUIRED=false

AUTH_SERVICE_NAME=auth-service
AUTH_SERVICE_PORT=8001
AUTH_REDIS_URL=redis://:change_me@redis:6379/0

PROJECT_SERVICE_NAME=project-service
PROJECT_SERVICE_PORT=8002
PROJECT_REDIS_URL=redis://:change_me@redis:6379/1

AGENT_SERVICE_NAME=agent-service
AGENT_SERVICE_PORT=8003
AGENT_REDIS_URL=redis://:change_me@redis:6379/2

TASK_SERVICE_NAME=task-service
TASK_SERVICE_PORT=8004
TASK_REDIS_URL=redis://:change_me@redis:6379/3
TASK_QUEUE_NAME=task-service:queue
TASK_WORKER_BLOCK_SECONDS=5
TASK_DEFAULT_MAX_ATTEMPTS=3

WORKFLOW_SERVICE_NAME=workflow-service
WORKFLOW_SERVICE_PORT=8005
WORKFLOW_REDIS_URL=redis://:change_me@redis:6379/4
WORKFLOW_ENGINE_URL=http://workflow-engine:8100

WORKFLOW_ENGINE_NAME=workflow-engine
WORKFLOW_ENGINE_PORT=8100
WORKFLOW_SERVICE_URL=http://workflow-service:8005
WORKFLOW_ENGINE_REDIS_URL=redis://:change_me@redis:6379/5
WORKFLOW_ENGINE_BROKER_STREAM=workflow-events
EXECUTION_QUEUE_NAME=workflow-engine:queue
EXECUTION_STATE_PREFIX=workflow-engine:execution
EXECUTION_INDEX_KEY=workflow-engine:executions
EXECUTION_WORKER_BLOCK_SECONDS=5
MAX_DELAY_SECONDS=5

AGENT_RUNTIME_NAME=agent-runtime
AGENT_RUNTIME_PORT=8200
AGENT_RUNTIME_URL=http://agent-runtime:8200
AGENT_RUNTIME_REDIS_URL=redis://:change_me@redis:6379/6
AGENT_RUNTIME_DEFAULT_MODEL=gpt-4.1-mini
AGENT_RUNTIME_TOOL_TIMEOUT_SECONDS=30
PROJECT_SERVICE_URL=http://project-service:8002
# 留空表示自动发现并加载全部工具；若需限制可填逗号分隔，例如：wordpress,facebook,wpcli,ssh_command
ENABLED_TOOL_PLUGINS=
MEMORY_KEY_PREFIX=agent-runtime:memory
ANALYTICS_KEY_PREFIX=agent-runtime:analytics
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
CLAUDE_API_KEY=
CLAUDE_BASE_URL=https://api.anthropic.com/v1
LOCAL_MODEL_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL_API_KEY=
LLM_REQUEST_TIMEOUT_SECONDS=30
# Knowledge base: Qdrant + OpenAI embeddings (used by project-service)
QDRANT_URL=http://qdrant:6333

# Admin service (quota check, usage ingest) - used by task-service, agent-runtime, workflow-engine
ADMIN_SERVICE_URL=http://admin-service:8007
# Encrypt system config secrets in DB (admin backend). Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SYSTEM_CONFIG_ENCRYPTION_KEY=

NEXT_PUBLIC_APP_NAME=AI Workforce Platform
NEXT_PUBLIC_AUTH_SERVICE_URL=http://localhost:8001
NEXT_PUBLIC_PROJECT_SERVICE_URL=http://localhost:8002
NEXT_PUBLIC_AGENT_SERVICE_URL=http://localhost:8003
NEXT_PUBLIC_TASK_SERVICE_URL=http://localhost:8004
NEXT_PUBLIC_WORKFLOW_SERVICE_URL=http://localhost:8005
NEXT_PUBLIC_WORKFLOW_ENGINE_URL=http://localhost:8100
NEXT_PUBLIC_AGENT_RUNTIME_URL=http://localhost:8200
NEXT_TELEMETRY_DISABLED=1
